# 🔑 Credenciales de Exnova
EXNOVA_EMAIL=tu_email@exnova.com
EXNOVA_PASSWORD=tu_password_aqui

# 💼 Configuración de Trading
ACCOUNT_TYPE=PRACTICE
CAPITAL_PER_TRADE=1.0
EXPIRATION_TIME=60

# 🛡️ Gestión de Riesgo
USE_MARTINGALE=False
MAX_CONSECUTIVE_LOSSES=3
MAX_DAILY_LOSS=50.0
MAX_SIMULTANEOUS_POSITIONS=3

# 🤖 IA
USE_LLM=False

# 📊 Logging
LOG_LEVEL=INFO
CONSOLE_OUTPUT=True

# 💾 Base de datos
DB_TYPE=sqlite
DB_PATH=./data/trading_bot.db
